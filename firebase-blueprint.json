{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account data in the system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "pin": { "type": "string" },
        "role": { "type": "string" },
        "customRole": { "type": "string" },
        "verified": { "type": "boolean" },
        "profilePic": { "type": "string" },
        "isBanned": { "type": "boolean" },
        "balance": { "type": "number" }
      },
      "required": ["id", "username", "password", "pin", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Information about items put for sale",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "description": { "type": "string" },
        "images": { "type": "array" },
        "sellerId": { "type": "string" }
      },
      "required": ["id", "title", "category", "price", "stock", "sellerId"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Trade instances / items purchased",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "number" },
        "sellerId": { "type": "string" },
        "buyerId": { "type": "string" },
        "qty": { "type": "number" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["waiting_confirmation", "completed", "cancelled"] },
        "timestamp": { "type": "number" },
        "deliveryCode": { "type": "string" },
        "paymentMethod": { "type": "string" }
      },
      "required": ["id", "productId", "sellerId", "buyerId", "qty", "totalPrice", "status", "timestamp"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Real-time communication between buyer and seller",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "number" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "any" },
        "isRead": { "type": "boolean" }
      },
      "required": ["id", "productId", "senderId", "receiverId", "text", "timestamp"]
    },
    "BannerConfig": {
      "title": "BannerConfig",
      "description": "Configurable active promo banners shown in slide deck",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "buttonText": { "type": "string" },
        "buttonLink": { "type": "string" },
        "bgColor": { "type": "string" },
        "accentColor": { "type": "string" }
      },
      "required": ["id", "title"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user accounts"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Marketplace products list"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Deals / trades made by clients"
    },
    "/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "Live messaging logs"
    },
    "/banner/{bannerId}": {
      "schema": "BannerConfig",
      "description": "Active carousel banner cards"
    }
  }
}
